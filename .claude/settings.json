      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh release view:*)",
      "Bash(gh release list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(gh api repos/:*)",
      "Bash(gh workflow list:*)",
      "Bash(gh workflow view:*)",

      "Bash(echo:*)",
      "Bash(printf:*)",
