      "PowerShell(Select-Object:*)",
      "PowerShell(Sort-Object:*)",
      "PowerShell(Group-Object:*)",
      "PowerShell(ConvertFrom-Json:*)",
      "PowerShell(ConvertTo-Json:*)",
      "PowerShell(Write-Output:*)",
      "PowerShell(Write-Host:*)"
    ],

    "_comment_deny": "Use 'deny' to globally block patterns regardless of allow list. The hook covers the most dangerous cases; this list adds a belt for things the hook regex might miss.",
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -fdx:*)",
      "Bash(git branch -D:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh release delete:*)",
      "Bash(npm publish:*)",
      "Bash(pnpm publish:*)",
      "Bash(cargo publish:*)"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/block_dangerous_commands.py"
          }
        ]
      }
    ]
  }
}
