      "Bash(python --version)",
      "Bash(python -V)",
      "Bash(python -m py_compile:*)",
      "Bash(python -m json.tool:*)",
      "Bash(python -m pytest:*)",
      "Bash(python -m mypy:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(black:*)",
      "Bash(isort:*)",
      "Bash(uv --version)",
      "Bash(uv run:*)",
      "Bash(uv sync:*)",
      "Bash(uv lock:*)",
      "Bash(uv pip list:*)",

      "Bash(go version)",
      "Bash(go test:*)",
      "Bash(go build:*)",
      "Bash(go vet:*)",
      "Bash(go mod tidy)",
      "Bash(go mod download)",
      "Bash(gofmt:*)",
      "Bash(golangci-lint:*)",

      "Bash(cargo --version)",
      "Bash(cargo build:*)",
      "Bash(cargo test:*)",
      "Bash(cargo check:*)",
      "Bash(cargo clippy:*)",
