{
  "_comment_overview": "Two things at work here: (1) permissions.allow pre-approves the read-mostly + test/build/format/git-local commands Claude runs constantly, so you don't click 'Approve' a hundred times a day. (2) The PreToolUse hook still runs block_dangerous_commands.py on every Bash/PowerShell invocation, so destructive ops like 'rm -rf', force-push, git reset --hard, reading .env, printing $TOKEN env vars stay blocked. Net effect: low friction, safety floor intact. Anything not in 'allow' below still prompts you the first time.",

  "permissions": {
    "defaultMode": "acceptEdits",

    "allow": [
      "Read(*)",

      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(tree:*)",
      "Bash(file:*)",
      "Bash(which:*)",
      "Bash(grep:*)",

      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git remote:*)",
      "Bash(git stash list:*)",
      "Bash(git config --get:*)",
      "Bash(git ls-files:*)",
      "Bash(git ls-remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(git add:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git tag:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git pull --rebase:*)",
      "Bash(git pull --ff-only:*)",

      "Bash(node --version)",
      "Bash(node -v)",
      "Bash(npm --version)",
      "Bash(npm ls:*)",
      "Bash(npm test:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm run type-check:*)",
      "Bash(npm run build:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run start:*)",
      "Bash(npm run format:*)",
      "Bash(npx prettier:*)",
      "Bash(npx eslint:*)",
      "Bash(npx tsc:*)",
      "Bash(npx vitest:*)",
      "Bash(npx jest:*)",
      "Bash(npx playwright test:*)",
      "Bash(npx playwright install:*)",
      "Bash(npm install)",
      "Bash(pnpm install)",
      "Bash(pnpm test:*)",
